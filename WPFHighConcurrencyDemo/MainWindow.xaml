<Window x:Class="WPFHighConcurrencyDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WPFHighConcurrencyDemo"
        Title="WPF 高并发监控面板" Height="800" Width="1000"
        Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="0,5,0,10">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Height="45" Margin="10,0">
                    <TextBlock Text="设备总数:" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="TxtCount" Text="5000" Width="60" VerticalContentAlignment="Center" Margin="5,10"/>

                    <TextBlock Text="方块尺寸:" Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <TextBox x:Name="TxtSize" Text="16" Width="40" VerticalContentAlignment="Center" Margin="5,10"/>

                    <Button Content="刷新网格" Click="BtnInit_Click" Margin="15,10" Padding="15,0" FontWeight="Bold"/>

                    <TextBlock x:Name="TxtInfo" Foreground="#00FFCC" VerticalAlignment="Center" Margin="20,0"/>

                    <TextBlock Text="SignalR 路由:" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="TxtHubUrl" Text="http://localhost:5294/monitorHub" Width="220" VerticalContentAlignment="Center" Margin="5,10"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Height="45" Margin="10,0">
                    <Button x:Name="BtnSim" Content="本地模拟" Click="BtnStartSimulation_Click" 
                            Margin="5,10" Padding="15,0" Background="#27AE60" Foreground="White" BorderThickness="0"/>

                    <Button x:Name="BtnHub" Content="连接SignalR" Click="BtnConnectHub_Click" 
                            Margin="15,10" Padding="15,0" Background="#2980B9" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="10,10,10,5" BorderBrush="#333" BorderThickness="1">
            <local:RealTimeChartControl x:Name="ChartControl" />
        </Border>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#2D2D30"/>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="10,5,10,10">
            <local:DeviceMapControl x:Name="MapControl" />
        </ScrollViewer>
    </Grid>
</Window>